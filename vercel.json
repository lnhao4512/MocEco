{
  "version": 2,
  "buildCommand": "npm run build",
  "outputDirectory": "client-customer/build",
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "https://mocecopure-server.onrender.com/api/$1"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}
