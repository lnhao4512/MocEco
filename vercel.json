{
  "version": 2,
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "https://moceco.onrender.com/api/$1"
    },
    {
      "source": "/uploads/(.*)",
      "destination": "https://moceco.onrender.com/uploads/$1"
    },
    {
      "source": "/socket.io/(.*)",
      "destination": "https://moceco.onrender.com/socket.io/$1"
    },
    {
      "source": "/admin/(.*)",
      "destination": "/admin/index.html"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}
